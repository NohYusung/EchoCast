{
    "family": "echocast-back-task-dev",
    "taskRoleArn": "__TASK_ROLE_ARN__",
    "executionRoleArn": "__EXECUTION_ROLE_ARN__",
    "networkMode": "bridge",
    "requiresCompatibilities": ["EC2"],
    "containerDefinitions": [
        {
            "name": "echocast-back-dev",
            "image": "__IMAGE_URI__",
            "cpu": 256,
            "memoryReservation": 512,
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 0,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "NODE_ENV",
                    "value": "production"
                },
                {
                    "name": "PORT",
                    "value": "3000"
                }
            ],
            "secrets": [
                {
                    "name": "ECHOCAST_DB_HOST",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_DB_HOST::"
                },
                {
                    "name": "ECHOCAST_DB_PORT",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_DB_PORT::"
                },
                {
                    "name": "ECHOCAST_DB_USERNAME",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_DB_USERNAME::"
                },
                {
                    "name": "ECHOCAST_DB_PASSWORD",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_DB_PASSWORD::"
                },
                {
                    "name": "ECHOCAST_DB_DATABASE",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_DB_DATABASE::"
                },
                {
                    "name": "ECHOCAST_AWS_BUCKET_NAME",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_AWS_BUCKET_NAME::"
                },
                {
                    "name": "ECHOCAST_AWS_REGION",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_AWS_REGION::"
                },
                {
                    "name": "ECHOCAST_AWS_URL",
                    "valueFrom": "__SECRET_ARN__:ECHOCAST_AWS_URL::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "__LOG_GROUP__",
                    "awslogs-region": "__AWS_REGION__",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "mountPoints": [],
            "volumesFrom": [],
            "systemControls": []
        }
    ],
    "volumes": [],
    "placementConstraints": []
}
